APP_NAME=CommandCenter
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://commandcenter.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# --- Command Center ---
# Absolute path to this checkout. Consumer projects reference this in
# their universal self-registration prompt to call `php artisan cc:register`.
COMMANDCENTER_HOME=

# Pin the user-profile dir that holds .claude/, .claude-savvior/, etc.
# Apache on Windows often runs as SYSTEM and cannot resolve $HOME or
# $USERPROFILE -- set this explicitly. Leave blank on POSIX boxes where
# $HOME is already exported in the service environment.
COMMANDCENTER_HOME_ROOT=

# Map account label -> executable used in the dashboard's "copy resume"
# command for that account. Comma-separated label:executable pairs.
# Falls back to "claude" for any account not listed.
# Example: CLAUDE_EXECUTABLES=personal:claude,savvior:claude-savvior
CLAUDE_EXECUTABLES=

VITE_APP_NAME="${APP_NAME}"
