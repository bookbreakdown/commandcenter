# Per-PC config for commandcenter. Copy to `.env` and edit values.
# This file is read by src/Database.php at request time, so values land in
# the dashboard even when Apache runs as a service that does not see your
# user-level shell env vars.

# Absolute path to this commandcenter checkout. Consumer projects use this
# (via the universal self-registration prompt) to locate bin/cc-register.
COMMANDCENTER_HOME=/path/to/commandcenter

# Where Claude Code stores its session JSONL files. The dashboard discovers
# sessions by globbing <CLAUDE_PROJECTS_DIR>/<encoded-cwd>/*.jsonl.
#
# Most setups:
#   Linux/macOS default:  $HOME/.claude/projects     (leave both blank)
#   Windows default:      $USERPROFILE/.claude/projects (leave both blank)
#
# When you alias Claude Code to a non-default config tree (e.g. a personal
# vs work account), set ONE of these:
#
#   CLAUDE_PROJECTS_DIR -- full path to the projects/ dir (most explicit)
#   CLAUDE_HOME         -- parent dir; commandcenter appends "/projects"
#
# Multi-account support is not yet implemented; for now point at whichever
# account you most often want the dashboard to discover. (Future: comma-list.)
#CLAUDE_PROJECTS_DIR=
#CLAUDE_HOME=
