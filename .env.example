# Copy to `.env` on each PC and set the absolute path to this repo so
# consumer projects can locate bin/cc-register via $COMMANDCENTER_HOME
# (see Setup in CLAUDE.md). The actual env var must also be exported in
# your shell rc (~/.bashrc, ~/.zshrc, $PROFILE) or set as a system env
# var -- this file is just a per-PC record of the value.

COMMANDCENTER_HOME=/path/to/commandcenter
